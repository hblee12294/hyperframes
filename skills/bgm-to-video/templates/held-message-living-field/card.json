{
  "id": "held-message-living-field",
  "name": "Held Message / Living Field",
  "one_line": "A readable mark held dead still over a soft, color-shifting blurred field.",
  "status": "promoted",
  "created": "2026-06-17",

  "match": {
    "structural_type": "sustained_hold",
    "requires": {
      "energy_level": ">=MEDIUM",
      "density": "sparse",
      "onset_gap_bars": ">=1.5",
      "has_steady_grid": true
    },
    "mood_fit": ["warm", "dark", "elegant", "cinematic"],
    "span_bars": [2, 8],
    "exit_trigger": ["first_onset_reentry", "hard_stop"]
  },

  "examples": [
    {
      "sample": "bgm_test_2",
      "group": "g1",
      "bpm": 129.2,
      "energy": 0.8,
      "density": "sparse",
      "onset_gap_bars": 2.05,
      "span_sec": [0.0, 4.017]
    }
  ],

  "roles": {
    "message": {
      "kind": "message",
      "motion": "freeze_after_reveal",
      "anchor": "entry.downbeat",
      "notes": "a held title block (mark + title + tagline); reveal (blur+scale settle, brief per-letter entrance) then dead still for the whole span — no ongoing motion, there are no onsets"
    },
    "field": {
      "kind": "background",
      "motion": "energy_envelope_breath",
      "anchor": "energy",
      "notes": "the only thing moving; colorful chromatic light-leak at entry, breathes up on the SURGE, then a black mask settles it to near-black with a central glow for the hold"
    }
  },

  "params": {
    "markText": { "type": "string", "maps_to": "message.mark", "default": "HF" },
    "titleText": { "type": "string", "maps_to": "message.title", "default": "HYPERFRAMES" },
    "tagText": { "type": "string", "maps_to": "message.tag", "default": "HTML · SHADERS · MP4" },
    "palette": {
      "type": "object",
      "keys": ["bgColor", "colorLow", "colorMid", "colorHigh", "accentColor"]
    },
    "flowSpeed": { "type": "number", "default": 1 },
    "duration": { "type": "number", "from": "group.span length" }
  },

  "reference_impl": "index.html (generic webgl-textures-playground; the group_1 DUCKLIFE recreate is one parameterization)",
  "uses_primitives": ["blur_resolve", "negative_space_hold", "chromatic_pressure", "hard_cut"],

  "transition_out": { "default": "fast_cut", "observed": "anticipation_glitch_cut" },

  "reversed_from": ["bgm-golden-sample-reverse/gorup-by-group/group_1"]
}
